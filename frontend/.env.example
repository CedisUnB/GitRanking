# Supabase Connection String
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://postgres:your_password@db.i2d2f3a4k3e.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # generate with: openssl rand -base64 32

# GitHub App OAuth credentials (https://github.com/settings/apps)
GITHUB_ID="" # numeric Client ID from your GitHub OAuth App settings
GITHUB_SECRET="" # Client Secret from your GitHub OAuth App settings

# GitHub App - used to fetch installation-specific repos
GITHUB_APP_ID=""                  # numeric App ID from your GitHub App settings
GITHUB_APP_PRIVATE_KEY=""         # base64-encoded PEM: base64 -i your-key.pem | tr -d '\n'
GITHUB_APP_INSTALLATION_URL=""    # e.g. https://github.com/apps/your-app-name/installations/new
