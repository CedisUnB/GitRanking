// This is your Prisma schema file for Supabase
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  username  String
  name      String?
  email     String?
  avatarUrl String?
  createdAt DateTime @default(now())

  userBadges UserBadges[]

  votesForHeroOfSprints VotesForHeroOfSprint[] @relation("VotesForHeroOfSprint_voter")

  sentRecognitionMessages RecognitionMessage[] @relation("Recognition_sender")

  receivedRecognitionMessages RecognitionMessage[] @relation("Recognition_recipient")

  nominatedVotesForHeroOfSprints VotesForHeroOfSprint[] @relation("VotesForHeroOfSprint_nominee")
}

/// A GitHub repository that has been accessed via the app at least once.
model Repository {
  id              String   @id @default(cuid())
  githubRepoId    String   @unique  // numeric GitHub repo ID — stable across renames
  owner           String            
  name            String            
  fullName        String            
  private         Boolean
  firstAccessedAt DateTime @default(now())

  userBadges            UserBadges[]
  recognitionMessages   RecognitionMessage[]
  votesForHeroOfSprints VotesForHeroOfSprint[]
}

model Badges {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon_url    String

  userBadges UserBadges[]
}

model UserBadges {
  id           String   @id @default(cuid())
  userId       String
  badgeId      String
  repositoryId String?
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  badge      Badges      @relation(fields: [badgeId], references: [id])
  repository Repository? @relation(fields: [repositoryId], references: [id])

  @@unique([userId, badgeId])
}

model VotesForHeroOfSprint {
  id           String   @id @default(cuid())
  voterId      String
  nomineeId    String
  sprintId     String
  repositoryId String?
  createdAt    DateTime @default(now())

  voter      User        @relation("VotesForHeroOfSprint_voter", fields: [voterId], references: [id])
  nominee    User        @relation("VotesForHeroOfSprint_nominee", fields: [nomineeId], references: [id])
  repository Repository? @relation(fields: [repositoryId], references: [id])
}

model RecognitionMessage {
  id           String   @id @default(cuid())
  senderId     String
  recipientId  String
  message      String
  reason       String
  repositoryId String?
  createdAt    DateTime @default(now())

  sender     User        @relation("Recognition_sender", fields: [senderId], references: [id])
  recipient  User        @relation("Recognition_recipient", fields: [recipientId], references: [id])
  repository Repository? @relation(fields: [repositoryId], references: [id])
}
