// This is your Prisma schema file for Supabase
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  username  String
  name      String?
  email     String?
  avatarUrl String?
  createdAt DateTime @default(now())
}
