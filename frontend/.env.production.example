# Production database on the VPS host.
# The production containers use host networking on the VPS.
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT="5432"
POSTGRES_DB="git_ranking"
POSTGRES_USER="git_ranking_appuser"
POSTGRES_PASSWORD=""
DATABASE_URL="postgresql://git_ranking_appuser:[YOUR-PASSWORD]@127.0.0.1:5432/git_ranking?schema=public"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Public application URL
NEXTAUTH_URL="https://gitranking.cedis.tec.br"
NEXTAUTH_SECRET=""

# GitHub OAuth App
GITHUB_ID=""
GITHUB_SECRET=""

# GitHub App
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_INSTALLATION_URL="https://github.com/apps/your-app-name/installations/new"

# Deploy settings used by scripts/deploy_production.zsh
APP_PORT="13000"
NGINX_SERVER_NAME="gitranking.cedis.tec.br"
NGINX_SSL_CERTIFICATE="/etc/letsencrypt/live/gitranking.cedis.tec.br/fullchain.pem"
NGINX_SSL_CERTIFICATE_KEY="/etc/letsencrypt/live/gitranking.cedis.tec.br/privkey.pem"
NGINX_CLIENT_MAX_BODY_SIZE="20M"